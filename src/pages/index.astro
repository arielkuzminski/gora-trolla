---
import { getCollection } from 'astro:content';
import HomePageContent from '../components/HomePageContent.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const concertEntries = await getCollection('concerts');
const allConcerts = concertEntries
  .map((entry) => entry.data)
  .sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime());

const now = new Date();
now.setHours(0, 0, 0, 0);

const teaserConcerts = allConcerts
  .filter((concert) => new Date(concert.date).getTime() >= now.getTime())
  .slice(0, 3);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'MusicGroup',
  name: 'Góra Trolla',
  alternateName: 'Góra Trolla Zespół Muzyki Dawnej',
  description: 'Polski zespół muzyki dawnej specjalizujący się w repertuarze średniowiecznym, renesansowym i barokowym.',
  url: 'https://goratrolla.pl',
  logo: 'https://goratrolla.pl/assets/images/icons/logo.svg',
  genre: [
    'Early Music',
    'Medieval Music',
    'Renaissance Music',
    'Baroque Music',
    'Muzyka Dawna',
    'Muzyka Średniowieczna',
    'Muzyka Renesansowa',
    'Muzyka Barokowa',
    'Muzyka Fantasy',
  ],
  foundingDate: '2008',
  foundingLocation: {
    '@type': 'Place',
    addressCountry: 'PL',
    addressLocality: 'Rumia',
    addressRegion: 'Trójmiasto',
  },
  areaServed: [
    { '@type': 'City', name: 'Gdańsk' },
    { '@type': 'City', name: 'Gdynia' },
    { '@type': 'City', name: 'Rumia' },
    { '@type': 'AdministrativeArea', name: 'Trójmiasto' },
    { '@type': 'Country', name: 'Polska' },
  ],
  sameAs: [
    'https://www.facebook.com/goratrolla',
    'https://www.instagram.com/goratrolla',
    'https://www.youtube.com/@goratrolla',
  ],
};
---

<BaseLayout
  title="Góra Trolla - Zespół Muzyki Dawnej | Strona Główna"
  description="Góra Trolla - zespół muzyki dawnej z Trójmiasta. Muzyka średniowieczna, renesansowa i barokowa, koncerty, wydarzenia historyczne i festiwale."
  lang="pl"
  currentPage="home"
  canonicalUrl="https://goratrolla.pl/"
  ogLocale="pl_PL"
  alternates={{
    pl: 'https://goratrolla.pl/',
    en: 'https://goratrolla.pl/en/',
  }}
  ogTitle="Góra Trolla - Zespół Muzyki Dawnej"
  ogDescription="Polski zespół muzyki dawnej - repertuar średniowieczny, renesansowy i barokowy."
  jsonLd={jsonLd}
>
  <HomePageContent lang="pl" teaserConcerts={teaserConcerts} allConcerts={allConcerts} />
</BaseLayout>
