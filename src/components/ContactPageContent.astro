---
import Footer from './Footer.astro';
import Nav from './Nav.astro';
import PartnersMarquee from './PartnersMarquee.astro';

interface Props {
  lang: 'pl' | 'en';
}

const { lang } = Astro.props;

const email = 'arispen@gmail.com';
const emailRot13 = 'nevfcra@tznvy.pbz';
const phone = '+48 604 222 452';

const copy = {
  pl: {
    skipLink: 'Przejdź do treści głównej',
    heroEyebrow: 'Zaproś nas na wydarzenie',
    heroTitle: 'Kontakt — Góra Trolla',
    formLabel: 'Formularz Kontaktowy',
    formHeading: 'Roześlij wici',
    infoLabel: 'Dane Kontaktowe',
    infoHeading: 'Znajdź nas',
    responseNote: 'Odpiszemy w ciągu 48 godzin roboczych.',
    emailLabel: 'E-mail',
    locationLabel: 'Lokalizacja',
    locationName: 'Rumia / Trójmiasto, Polska',
    locationBody: 'Gramy w całej Polsce i za granicą. Najłatwiej złapać nas mailowo lub przez social media.',
    socialLabel: 'Social Media',
    socialHandle: '@goratrolla',
    motto: 'Per aspera ad musica',
    formName: 'Imię i nazwisko',
    formNamePlaceholder: 'Jan Kowalski',
    formEmail: 'Adres e-mail',
    formEmailPlaceholder: 'jan@example.com',
    formSubject: 'Temat',
    formMessage: 'Wiadomość',
    formMessagePlaceholder: 'Twoja wiadomość',
    formSubmit: 'Wyślij wiadomość',
    formLoading: 'Wysyłanie...',
    formSuccess: 'Dziękujemy! Odpiszemy wkrótce.',
    hiddenSubject: 'Wiadomość ze strony Góra Trolla',
    subjects: {
      concerts: 'Koncerty',
      collab: 'Współpraca',
      press: 'Prasa / Media',
      other: 'Inne',
    },
  },
  en: {
    skipLink: 'Skip to main content',
    heroEyebrow: 'Invite us to your event',
    heroTitle: 'Contact — Góra Trolla',
    formLabel: 'Contact Form',
    formHeading: 'Ask About a Concert',
    infoLabel: 'Contact Details',
    infoHeading: 'Find us',
    responseNote: 'We reply within 48 business hours.',
    emailLabel: 'Email',
    locationLabel: 'Location',
    locationName: 'Rumia / Tri-City, Poland',
    locationBody: 'We perform throughout Poland and abroad. The easiest way to reach us is by email or via social media.',
    socialLabel: 'Social Media',
    socialHandle: '@goratrolla',
    motto: 'Per aspera ad musica',
    formName: 'Full name',
    formNamePlaceholder: 'Jane Smith',
    formEmail: 'Email address',
    formEmailPlaceholder: 'jane@example.com',
    formSubject: 'Subject',
    formMessage: 'Message',
    formMessagePlaceholder: 'Your message',
    formSubmit: 'Send message',
    formLoading: 'Sending...',
    formSuccess: 'Thank you! We will reply shortly.',
    hiddenSubject: 'Message from www.gora-trolla.pl',
    subjects: {
      concerts: 'Concerts',
      collab: 'Collaboration',
      press: 'Press / Media',
      other: 'Other',
    },
  },
} as const;

const t = copy[lang];
---

<a class="skip-link" href="#main-content">{t.skipLink}</a>

<Nav lang={lang} currentPage="contact" />

<main id="main-content">
  <div class="gradient-flow">
  <div class="page-hero">
    <div class="page-hero__content container">
      <p class="t-eyebrow" style="margin-bottom:var(--space-3)">{t.heroEyebrow}</p>
      <h1 class="page-hero__title">{t.heroTitle}</h1>
      <span class="page-hero__title-underline"></span>
    </div>
  </div>

  <section class="section" aria-labelledby="contact-heading">
    <div class="container">
      <div class="grid-2" style="align-items:flex-start;gap:clamp(var(--space-12),6vw,var(--space-24))">
        <div data-animate="fade-up">
          <p class="section-label">{t.formLabel}</p>
          <h2 id="contact-heading" style="margin-bottom:var(--space-8)">{t.formHeading}</h2>

          <form
            class="contact-form"
            action="https://formspree.io/f/xwvaaqyj"
            method="POST"
            novalidate
          >
            <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />
            <input type="hidden" name="_subject" value={t.hiddenSubject} />

            <div class="form-field">
              <label class="form-label" for="contact-name">
                {t.formName} <span class="required" aria-hidden="true">*</span>
              </label>
              <input
                type="text"
                id="contact-name"
                name="name"
                class="form-input"
                placeholder={t.formNamePlaceholder}
                aria-required="true"
                autocomplete="name"
              />
            </div>

            <div class="form-field">
              <label class="form-label" for="contact-email">
                {t.formEmail} <span class="required" aria-hidden="true">*</span>
              </label>
              <input
                type="email"
                id="contact-email"
                name="email"
                class="form-input"
                placeholder={t.formEmailPlaceholder}
                aria-required="true"
                autocomplete="email"
              />
            </div>

            <div class="form-field">
              <label class="form-label" for="contact-subject">{t.formSubject}</label>
              <select id="contact-subject" name="subject" class="form-select">
                <option value={t.subjects.concerts}>{t.subjects.concerts}</option>
                <option value={t.subjects.collab}>{t.subjects.collab}</option>
                <option value={t.subjects.press}>{t.subjects.press}</option>
                <option value={t.subjects.other}>{t.subjects.other}</option>
              </select>
            </div>

            <div class="form-field">
              <label class="form-label" for="contact-message">
                {t.formMessage} <span class="required" aria-hidden="true">*</span>
              </label>
              <textarea
                id="contact-message"
                name="message"
                class="form-textarea"
                placeholder={t.formMessagePlaceholder}
                aria-required="true"
              ></textarea>
            </div>

            <div style="margin-top:var(--space-8)">
              <button
                type="submit"
                class="btn btn--primary"
                style="width:100%;justify-content:center"
                data-submit={t.formSubmit}
                data-loading={t.formLoading}
              >
                {t.formSubmit}
              </button>
            </div>

            <p style="margin-top:var(--space-4);font-size:var(--text-xs);color:var(--color-faded);text-align:center">
              {t.responseNote}
            </p>
          </form>

          <div class="form-success" role="alert" aria-live="assertive">
            {t.formSuccess}
          </div>
        </div>

        <div data-animate="slide-right">
          <p class="section-label">{t.infoLabel}</p>
          <h2 style="margin-bottom:var(--space-8)">{t.infoHeading}</h2>

          <div
            style="padding:var(--space-6);background:var(--color-glass);border:var(--border-gold);border-radius:var(--radius-md);margin-bottom:var(--space-4);backdrop-filter:var(--glass-blur)"
          >
            <p style="font-family:var(--font-heading);font-size:var(--text-xs);letter-spacing:var(--tracking-caps);text-transform:uppercase;color:var(--color-gold-bright);margin-bottom:var(--space-2)">
              {t.emailLabel}
            </p>
            <a
              href="#"
              data-email={emailRot13}
              style="font-family:var(--font-body);font-size:var(--text-lg);color:var(--color-parchment)"
            >{email}</a>
          </div>

          <div
            style="padding:var(--space-6);background:var(--color-glass);border:var(--border-gold);border-radius:var(--radius-md);margin-bottom:var(--space-4);backdrop-filter:var(--glass-blur)"
          >
            <p style="font-family:var(--font-heading);font-size:var(--text-xs);letter-spacing:var(--tracking-caps);text-transform:uppercase;color:var(--color-gold-bright);margin-bottom:var(--space-2)">
              {lang === 'pl' ? 'Telefon' : 'Phone'}
            </p>
            <a href={`tel:${phone.replace(/\s/g, '')}`} style="font-family:var(--font-body);font-size:var(--text-lg);color:var(--color-parchment)">{phone}</a>
          </div>

          <div
            style="padding:var(--space-6);background:var(--color-glass);border:var(--border-gold);border-radius:var(--radius-md);margin-bottom:var(--space-4);backdrop-filter:var(--glass-blur)"
          >
            <p style="font-family:var(--font-heading);font-size:var(--text-xs);letter-spacing:var(--tracking-caps);text-transform:uppercase;color:var(--color-gold-bright);margin-bottom:var(--space-2)">
              {t.locationLabel}
            </p>
            <p style="font-size:var(--text-lg);color:var(--color-parchment)">{t.locationName}</p>
            <p style="font-size:var(--text-sm);color:var(--color-vellum);margin-top:var(--space-1)">{t.locationBody}</p>
          </div>

          <div
            style="padding:var(--space-6);background:var(--color-glass);border:var(--border-gold);border-radius:var(--radius-md);backdrop-filter:var(--glass-blur)"
          >
            <p style="font-family:var(--font-heading);font-size:var(--text-xs);letter-spacing:var(--tracking-caps);text-transform:uppercase;color:var(--color-gold-bright);margin-bottom:var(--space-4)">
              {t.socialLabel}
            </p>
            <div style="display:flex;flex-direction:column;gap:var(--space-3)">
              <a
                href="https://www.facebook.com/goratrolla"
                target="_blank"
                rel="noopener"
                style="display:flex;align-items:center;gap:var(--space-3);color:var(--color-vellum);transition:color 0.2s"
              >
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="color:var(--color-gold-bright);flex-shrink:0"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
                <span>Facebook</span>
                <span style="font-size:var(--text-xs);color:var(--color-faded)">{t.socialHandle}</span>
              </a>

              <a
                href="https://www.instagram.com/goratrolla"
                target="_blank"
                rel="noopener"
                style="display:flex;align-items:center;gap:var(--space-3);color:var(--color-vellum);transition:color 0.2s"
              >
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" style="color:var(--color-gold-bright);flex-shrink:0"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
                <span>Instagram</span>
                <span style="font-size:var(--text-xs);color:var(--color-faded)">{t.socialHandle}</span>
              </a>

            </div>

            <div class="ornament" style="margin:var(--space-8) 0 0">
              <span class="ornament-symbol">✦</span>
            </div>
            <p style="font-family:var(--font-accent);font-size:var(--text-lg);color:var(--color-gold-bright);text-align:center">
              {t.motto}
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
  </div>
  <PartnersMarquee lang={lang} />
</main>

<Footer lang={lang} />

<script define:vars={{ lang }}>
  localStorage.setItem('gt-lang', lang);
</script>
