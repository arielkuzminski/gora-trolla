---
interface Props {
  lang: 'pl' | 'en';
}

const { lang } = Astro.props;

const labels = {
  pl: {
    tagline:      'Muzyka Dawna',
    navAriaLabel: 'Nawigacja stopki',
    copyright:    'Wszelkie prawa zastrzeżone',
    home:         'Strona Główna',
    about:        'O Nas',
    concerts:     'Koncerty',
    contact:      'Kontakt',
  },
  en: {
    tagline:      'Early Music',
    navAriaLabel: 'Footer navigation',
    copyright:    'All rights reserved',
    home:         'Home',
    about:        'About',
    concerts:     'Concerts',
    contact:      'Contact',
  },
} as const;

const links = {
  pl: { home: '/', about: '/o-nas/', concerts: '/koncerty/', contact: '/kontakt/' },
  en: { home: '/en/', about: '/en/about/', concerts: '/en/concerts/', contact: '/en/contact/' },
} as const;

const t = labels[lang];
const l = links[lang];

const year = new Date().getFullYear();
---

<footer class="footer" role="contentinfo">
  <div class="footer__inner">

    <!-- Brand -->
    <div class="footer__brand">
      <a href={l.home} class="footer__logo-text">Góra Trolla</a>
      <div class="footer__tagline">{t.tagline}</div>

      <div class="footer__social">
        <a
          href="https://www.facebook.com/goratrolla"
          class="footer__social-link"
          aria-label="Facebook"
          target="_blank"
          rel="noopener"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
          </svg>
        </a>
        <a
          href="https://www.instagram.com/goratrolla"
          class="footer__social-link"
          aria-label="Instagram"
          target="_blank"
          rel="noopener"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Candle ornament -->
    <div class="footer__candle" aria-hidden="true">
      <svg class="candle__flame" width="18" height="28" viewBox="0 0 18 28" fill="none">
        <path d="M9 2 C6 6 3 10 3 15 C3 20 6 24 9 26 C12 24 15 20 15 15 C15 10 12 6 9 2Z" fill="#d4a843" opacity="0.9"/>
        <path d="M9 8 C7.5 11 6 14 6 17 C6 20 7.5 23 9 24" stroke="#f5e4a8" stroke-width="1" stroke-linecap="round" opacity="0.5"/>
      </svg>
      <svg width="12" height="40" viewBox="0 0 12 40" fill="none">
        <rect x="3" y="0" width="6" height="38" rx="1" fill="#3a3020" stroke="#d4a843" stroke-width="0.5"/>
        <line x1="0" y1="38" x2="12" y2="38" stroke="#d4a843" stroke-width="1"/>
      </svg>
    </div>

    <!-- Footer nav -->
    <nav class="footer__nav" aria-label={t.navAriaLabel}>
      <a href={l.home}>{t.home}</a>
      <a href={l.about}>{t.about}</a>
      <a href={l.concerts}>{t.concerts}</a>
      <a href={l.contact}>{t.contact}</a>
    </nav>

  </div>

  <div class="footer__bottom">
    <span>© {year} Góra Trolla</span>
    <span>{t.copyright}</span>
  </div>
</footer>
