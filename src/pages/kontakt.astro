---
import ContactPageContent from '../components/ContactPageContent.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'ContactPage',
    name: 'Kontakt - Góra Trolla',
    url: 'https://www.gora-trolla.pl/kontakt/',
    mainEntity: {
      '@type': 'MusicGroup',
      name: 'Góra Trolla',
      url: 'https://www.gora-trolla.pl',
      foundingDate: '2008',
      email: 'kontakt@www.gora-trolla.pl',
      areaServed: [
        { '@type': 'City', name: 'Gdańsk' },
        { '@type': 'City', name: 'Gdynia' },
        { '@type': 'City', name: 'Rumia' },
        { '@type': 'AdministrativeArea', name: 'Trójmiasto' },
      ],
      sameAs: [
        'https://www.facebook.com/goratrolla',
        'https://www.instagram.com/goratrolla',
      ],
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'MusicGroup',
    name: 'Góra Trolla',
    url: 'https://www.gora-trolla.pl',
    email: 'kontakt@www.gora-trolla.pl',
    foundingDate: '2008',
    areaServed: [
      { '@type': 'City', name: 'Gdańsk' },
      { '@type': 'City', name: 'Gdynia' },
      { '@type': 'City', name: 'Rumia' },
      { '@type': 'AdministrativeArea', name: 'Trójmiasto' },
    ],
    sameAs: [
      'https://www.facebook.com/goratrolla',
      'https://www.instagram.com/goratrolla',
    ],
  },
];
---

<BaseLayout
  title="Kontakt - Góra Trolla | Zespół Muzyki Dawnej"
  description="Skontaktuj się z zespołem Góra Trolla w sprawie koncertów, festiwali i współpracy. Muzyka dawna z Trójmiasta — zapytania o rezerwacje, prasę i media."
  lang="pl"
  currentPage="contact"
  canonicalUrl="https://www.gora-trolla.pl/kontakt/"
  ogLocale="pl_PL"
  alternates={{
    pl: 'https://www.gora-trolla.pl/kontakt/',
    en: 'https://www.gora-trolla.pl/en/contact/',
  }}
  ogTitle="Kontakt - Góra Trolla"
  ogDescription="Skontaktuj się z zespołem Góra Trolla."
  jsonLd={jsonLd}
>
  <ContactPageContent lang="pl" />
</BaseLayout>
