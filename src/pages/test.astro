---
/**
 * Strona testowa — weryfikacja Zadań 2–3 (BaseLayout + SEOHead + Nav).
 * Usuń po zakończeniu migracji.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { useTranslations } from '../i18n/utils';

const t = useTranslations('pl');
// Weryfikacja: t('nav.home') === 'Strona Główna'
// t('concerts.type_label.sacred') === 'Sakralne'

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'MusicGroup',
  name: 'Góra Trolla',
  description: 'Polski zespół muzyki dawnej',
  url: 'https://goratrolla.pl',
};
---

<BaseLayout
  title="Test — BaseLayout OK"
  description="Strona testowa weryfikująca BaseLayout i SEOHead."
  lang="pl"
  currentPage="test"
  canonicalUrl="https://goratrolla.pl/test/"
  ogLocale="pl_PL"
  jsonLd={jsonLd}
>
  <!--
    Przykład dodatkowego JSON-LD w <head> (np. Event schema dla strony koncertu).
    Użyj atrybutu slot="head" na elemencie który ma trafić do <head>:
    <script type="application/ld+json" slot="head">...</script>
  -->

  <Nav lang="pl" currentPage="home" />

  <main style="padding: 8rem 2rem; font-family: serif; color: #f2e8d0;">
    <h1 style="color: #d4a843;">BaseLayout + SEOHead + Nav + Footer — Zadania 2–4 ✓</h1>
    <p>Sprawdź:</p>
    <ul>
      <li>Nav u góry — PL, "Strona Główna" z aria-current="page"</li>
      <li>Footer na dole — social links, świeca, copyright z rokiem</li>
      <li>canonical, hreflang, og:*, twitter:*, JSON-LD w źródle</li>
    </ul>
  </main>

  <Footer lang="pl" />
</BaseLayout>
