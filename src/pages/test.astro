---
/**
 * Strona testowa — weryfikacja Zadań 2–7.
 * Usuń po zakończeniu migracji.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import HeroSection from '../components/HeroSection.astro';
import ConcertCard from '../components/ConcertCard.astro';
import GalleryItem from '../components/GalleryItem.astro';
import { useTranslations } from '../i18n/utils';
import { getCollection } from 'astro:content';

const t = useTranslations('pl');

// Verify i18n: t('nav.home') === 'Strona Główna'
// t('concerts.type_label.sacred') === 'Sakralne'

const concerts = await getCollection('concerts');
// Sort by date desc, take first upcoming
const upcoming = concerts
  .filter(c => new Date(c.data.date) >= new Date())
  .sort((a, b) => new Date(a.data.date).getTime() - new Date(b.data.date).getTime());
const sampleConcert = upcoming[0]?.data ?? concerts[0].data;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'MusicGroup',
  name: 'Góra Trolla',
  description: 'Polski zespół muzyki dawnej',
  url: 'https://goratrolla.pl',
};
---

<BaseLayout
  title="Test — Zadania 2–7"
  description="Strona testowa weryfikująca BaseLayout, SEOHead, Nav, Footer, HeroSection, ConcertCard, GalleryItem."
  lang="pl"
  currentPage="home"
  canonicalUrl="https://goratrolla.pl/test/"
  ogLocale="pl_PL"
  alternates={{
    pl: 'https://goratrolla.pl/test/',
    en: 'https://goratrolla.pl/en/',
    xDefault: 'https://goratrolla.pl/test/',
  }}
  jsonLd={jsonLd}
>
  <Nav lang="pl" currentPage="home" />

  <HeroSection
    tagline={t('hero.tagline')}
    heading="Góra Trolla"
    subheading={t('hero.tagline')}
    cta1Label={t('hero.cta_concerts')}
    cta1Href="/koncerty/"
    cta2Label={t('hero.cta_about')}
    cta2Href="/o-nas/"
    ariaLabel="Baner główny"
  />

  <main style="padding: 4rem 2rem; font-family: serif; color: #f2e8d0; max-width: 1200px; margin: 0 auto;">
    <h2 style="color: #d4a843;">Zadanie 7: ConcertCard + GalleryItem ✓</h2>

    <h3 style="color: #d4a843; margin-top: 2rem;">ConcertCard (1 nadchodzący):</h3>
    <div style="max-width: 400px;">
      <ConcertCard concert={sampleConcert} lang="pl" />
    </div>

    <h3 style="color: #d4a843; margin-top: 2rem;">GalleryItem (3 zdjęcia):</h3>
    <div class="gallery-grid" data-gallery="test" style="display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;max-width:800px;">
      <GalleryItem src="/media/band_1.jpg" alt="Góra Trolla" fullSrc="/media/band_1.jpg" caption="Góra Trolla — zdjęcie zespołowe" />
      <GalleryItem src="/media/band_2.jpg" alt="Zespół podczas występu" fullSrc="/media/band_2.jpg" caption="Zespół podczas występu" animateDelay={2} />
      <GalleryItem src="/media/band_3.jpg" alt="Wspólne granie" fullSrc="/media/band_3.jpg" caption="Wspólne granie na żywo" animateDelay={3} />
    </div>
  </main>

  <Footer lang="pl" />
</BaseLayout>
