---
import Footer from './Footer.astro';
import GalleryItem from './GalleryItem.astro';
import MusicianCard from './MusicianCard.astro';
import Nav from './Nav.astro';
import { musicians } from '../data/musicians';

interface Props {
  lang: 'pl' | 'en';
}

const { lang } = Astro.props;

const musicianMeta = {
  pl: {
    Ariel: { instrument: 'Dudy, szałamaje, flety', moreLabel: 'Więcej o Arielu' },
    'Rafał': { instrument: 'Buzuki irlandzkie, flety', moreLabel: 'Więcej o Rafale' },
    Krzysztof: { instrument: 'Mandola', moreLabel: 'Więcej o Krzysztofie' },
    'Jędrzej': { instrument: 'Davul', moreLabel: 'Więcej o Jędrzeju' },
    Maciej: { instrument: 'Wodzirej', moreLabel: 'Więcej o Macieju' },
    Jasio: { instrument: 'Człowiek orkiestra', moreLabel: 'Więcej o Jasiu' },
  },
  en: {
    Ariel: { instrument: 'Bagpipes, shawms, flutes', moreLabel: 'More about Ariel' },
    'Rafał': { instrument: 'Irish bouzouki, flutes', moreLabel: 'More about Rafał' },
    Krzysztof: { instrument: 'Mandola', moreLabel: 'More about Krzysztof' },
    'Jędrzej': { instrument: 'Davul', moreLabel: 'More about Jędrzej' },
    Maciej: { instrument: 'Master of Ceremonies', moreLabel: 'More about Maciej' },
    Jasio: { instrument: 'One-man band', moreLabel: 'More about Jasio' },
  }
} as const;

const copy = {
  pl: {
    skipLink: 'Przejdź do treści głównej',
    heroEyebrow: 'Historia i Muzyka',
    heroTitle: 'O Nas',
    historyLabel: 'Nasza Historia',
    historyHeading: 'Jak Powstała Góra Trolla',
    historyLead:
      'Dawno temu, w nadbałtyckim grodzie zwanym Rumią, zrodziło się coś, czemu trudno nadać inną nazwę niż przeznaczenie. Rok 2008. Dwaj licealiści — Ariel i Maciej — zbuntowali się pewnego dnia przeciw nudzie szkolnych ławek i zamiast słuchać lekcji, sięgnęli po flet i mandolinę. Nikt wówczas nie wiedział, że to nie wagary, lecz pierwszy rozdział legendy.',
    historyBody1:
      'Granie stało się ich tajemną akademią. Próba goniła próbę, a każda nuta zbliżała ich do muzyki, którą świat zdawał się zapomnieć — śpiewów trubadurów, tanecznych rytmów karczem sprzed wieków, głosów instrumentów, które dziś brzmią jak echo innego czasu. Zbierali na szałamaje i buzuki jak rycerze zbierają na zbroję — rok po roku, grosz po groszu, z myślą o tym jednym, pierwszym prawdziwym koncercie.',
    quote:
      'Nie interpretujemy muzyki dawnej. Próbujemy ją usłyszeć tak, jak słyszeli ją jej twórcy.',
    historyBody2:
      'W 2012 roku, w karczmarskiej sali pewnej tawerny w Rumi, szałamaje i irlandzkie buzuki zaśpiewały po raz pierwszy. Do drużyny dołączyli Rafał i Jędrzej — i tak ukształtował się rdzeń Góry Trolla. Czterech wędrownych grajków, których nic już nie rozdzieliło.',
    historyBody3:
      'Od podmiejskiej tawerny do całej Polski — od gdyńskiego Ucha przez Śląsk aż po wielkopolskie targi i kieleckie festiwale. Zdarzały się weekendy z trzema koncertami z rzędu. A w roku 2025 Góra Trolla po raz pierwszy przekroczyła granicę: w Bari, przy murach zamku, nad błękitem Adriatyku, zagrała ku czci Bony Sforzy. Polska nuta popłynęła po włoskim niebie.',
    timelineLabel: 'Kamienie Milowe',
    timeline: [
      {
        year: '2008',
        title: 'Narodziny w Rumii',
        body: 'W nadbałtyckiej Rumi, w szkolnych ławkach i na wagarach, zawiązała się przyjaźń i wspólna miłość do muzyki dawnej. Ariel i Maciej postanowili, że to, co zaczęło się od fletu i mandoliny, skończyć się nie może.'
      },
      {
        year: '2012',
        title: 'Pierwsza Karczma',
        body: 'W tawernie w Rumi szałamaje i irlandzkie buzuki zaśpiewały po raz pierwszy. Do drużyny dołączyli Rafał i Jędrzej. Góra Trolla stała się czteroosobowym filarem.'
      },
      {
        year: '2014',
        title: 'Trójmiejski Szlak',
        body: 'Klub Ucho w Gdyni, Folkowe Jare Gody, Folkowa Noc Kupały, okoliczne grodziska i festiwale średniowieczne — muzyka zaczęła znajdować drogi w szeroki świat.'
      },
      {
        year: '2018',
        title: 'Pyrkon: Brama do Polski',
        body: 'Na Pyrkonie w Poznaniu zagrali dla Blizzard Entertainment przy promocji Hearthstone. Muzyka średniowieczna i świat fantasy splotły się w jedno — i otworzyły bramę do tournée po całej Polsce.'
      },
      {
        year: '2025',
        title: 'Bari i Kielce: Nowe Lądy',
        body: 'Samolot, włoskie słońce, szum Adriatyku. Przy zamku w Bari — pierwszy koncert zagraniczny ku czci Bony Sforzy. Potem Scyzorykon w Kielcach. Szlak nie ma końca.'
      }
    ],
    philosophyLabel: 'Nasza Filozofia',
    philosophyHeading: 'Jak Tworzymy Muzykę',
    philosophy1Title: 'Żywe Instrumentarium',
    philosophy1Body:
      'Dudy śpiewają. Davul uderza jak serce wieków. Szałamaje przeszywają powietrze z mocą, która nie pochodzi z amplifikatora — pochodzi z setek lat pamięci drewna i metalu. Gramy na instrumentach zbudowanych według historycznych wzorców, bo wierzymy, że dźwięk nie kłamie. Kiedy instrument jest prawdziwy, muzyka — choć stara o wieki — odżywa.',
    philosophy2Title: 'W Służbie Rękopisu',
    philosophy2Body:
      'Zanim padnie pierwsza nuta, otwieramy kodeks. Sięgamy do manuskryptów, tabulatur i pieśni zapisanych przy świetle świecy przed wiekami — nie po to, by zbudować muzeum, lecz by nawiązać rozmowę z tymi, którzy pisali. Każda nasza aranżacja jest odpowiedzią na ich głos.',
    meetLabel: 'Poznaj Nas',
    meetHeading: 'Muzycy Góry Trolla',
    galleryLabel: 'Galeria Zespołu',
    galleryHeading: 'Góra Trolla na Scenie i Poza Nią',
    gallery: [
      { src: '/media/band_0.jpg', alt: 'Góra Trolla - zespół', caption: 'Góra Trolla - zespół' },
      { src: '/media/band_6.jpg', alt: 'Muzycy podczas koncertu', caption: 'Muzycy podczas koncertu' },
      { src: '/media/band_8.jpg', alt: 'Scena i instrumentarium', caption: 'Scena i instrumentarium' },
      { src: '/media/maciek_1.jpg', alt: 'Maciej podczas prowadzenia koncertu', caption: 'Maciej podczas prowadzenia koncertu' },
      { src: '/media/poznan_2.jpg', alt: 'Występ w Poznaniu', caption: 'Występ w Poznaniu' },
      { src: '/media/gdansk_1.jpg', alt: 'Góra Trolla w Gdańsku', caption: 'Góra Trolla w Gdańsku' }
    ]
  },
  en: {
    skipLink: 'Skip to main content',
    heroEyebrow: 'History & Music',
    heroTitle: 'About Us',
    historyLabel: 'Our History',
    historyHeading: 'How Góra Trolla Came to Be',
    historyLead:
      'Long ago, in the coastal town of Rumia by the Baltic Sea, something stirred that can only be called fate. The year was 2008. Two schoolboys — Ariel and Maciej — decided one day that classroom walls were no place for the music they carried in their chests. They reached for a flute and a mandolin. No one knew then that those stolen afternoon notes were the first lines of a legend.',
    historyBody1:
      'Truancy became their secret conservatory. Rehearsal followed rehearsal, and each note drew them closer to music the world seemed to have forgotten — the songs of troubadours, the dance rhythms of ancient taverns, the voices of instruments that ring today like echoes of another age. They saved for shawms and bouzoukis the way knights save for armour — coin by coin, year by year, with one thought fixed in mind: the first true concert.',
    quote:
      'We do not merely interpret early music. We try to hear it as its creators might have heard it.',
    historyBody2:
      'In 2012, inside a tavern hall in Rumia, shawms and an Irish bouzouki sang together for the first time. Rafał and Jędrzej joined the fellowship — and so the heart of Góra Trolla took shape. Four wandering minstrels that nothing would part.',
    historyBody3:
      'From a suburban tavern to the whole of Poland — from the Gdynia club Ucho through Silesia to the market squares of Wielkopolska and the festivals of Kielce. Some weekends brought three concerts in a row. Then came 2025, and Góra Trolla crossed a border for the first time: in Bari, beneath the walls of a medieval castle, by the blue Adriatic, they played in honour of Bona Sforza. A Polish note drifted over an Italian sky.',
    timelineLabel: 'Milestones',
    timeline: [
      {
        year: '2008',
        title: 'Born in Rumia',
        body: 'By the Baltic shore, in school desks and stolen afternoons, a friendship took root alongside a shared love for music the world had long stopped playing. Ariel and Maciej knew that what began with a flute and a mandolin could not simply end.'
      },
      {
        year: '2012',
        title: 'The First Tavern',
        body: 'In a Rumia tavern, shawms and an Irish bouzouki rang out for the first time. Rafał and Jędrzej joined the fellowship. Góra Trolla became a band of four.'
      },
      {
        year: '2014',
        title: 'The Tri-City Circuit',
        body: 'Club Ucho in Gdynia, Folkowe Jare Gody, Folkowa Noc Kupały, nearby medieval fairs and stronghold festivals — the music began finding paths into the wider world.'
      },
      {
        year: '2018',
        title: 'Pyrkon: The Gate Opens',
        body: 'At Pyrkon in Poznań they played for Blizzard Entertainment for the Hearthstone launch. Medieval music and the fantasy world intertwined — and a gate swung open to concert stages across all of Poland.'
      },
      {
        year: '2025',
        title: 'Bari and Kielce: New Horizons',
        body: 'A plane, Italian sun, the sound of the Adriatic. At Bari castle — their first international concert, in honour of Bona Sforza. Then Scyzorykon in Kielce. The road shows no sign of ending.'
      }
    ],
    philosophyLabel: 'Our Approach',
    philosophyHeading: 'How We Shape the Music',
    philosophy1Title: 'Living Instruments',
    philosophy1Body:
      'The bagpipes sing. The davul strikes like the heartbeat of ages. The shawms cut through the air with a force that needs no amplifier — only the memory held in centuries of wood and metal. We play instruments built to historical models because we believe sound does not lie. When the instrument is true, the music — however old — comes alive.',
    philosophy2Title: 'In Service of the Manuscript',
    philosophy2Body:
      'Before the first note is played, we open a codex. We reach for manuscripts, tablatures, and songs set down by candlelight centuries ago — not to reconstruct a museum piece, but to hold a conversation with those who wrote them. Every arrangement we make is an answer to their voice.',
    meetLabel: 'Meet Us',
    meetHeading: 'Musicians of Góra Trolla',
    galleryLabel: 'Band Gallery',
    galleryHeading: 'Góra Trolla On Stage and Beyond',
    gallery: [
      { src: '/media/band_0.jpg', alt: 'Góra Trolla ensemble', caption: 'Góra Trolla ensemble' },
      { src: '/media/band_6.jpg', alt: 'Musicians during a concert', caption: 'Musicians during a concert' },
      { src: '/media/band_8.jpg', alt: 'Stage and instrumentarium', caption: 'Stage and instrumentarium' },
      { src: '/media/maciek_1.jpg', alt: 'Maciej leading the audience', caption: 'Maciej leading the audience' },
      { src: '/media/poznan_2.jpg', alt: 'Performance in Poznan', caption: 'Performance in Poznan' },
      { src: '/media/gdansk_1.jpg', alt: 'Góra Trolla in Gdansk', caption: 'Góra Trolla in Gdansk' }
    ]
  }
} as const;

const t = copy[lang];
---

<a class="skip-link" href="#main-content">{t.skipLink}</a>

<Nav lang={lang} currentPage="about" />

<main id="main-content">
  <div class="gradient-flow">
  <div class="page-hero">
    <div class="page-hero__content container">
      <p class="t-eyebrow" style="margin-bottom:var(--space-3)">{t.heroEyebrow}</p>
      <h1 class="page-hero__title">{t.heroTitle}</h1>
      <span class="page-hero__title-underline"></span>
    </div>
  </div>
  <section class="section" aria-labelledby="history-heading">
    <div class="container container--narrow">
      <div data-animate="fade-up">
        <p class="section-label">{t.historyLabel}</p>
        <h2 id="history-heading" style="margin-bottom:var(--space-8)">{t.historyHeading}</h2>

        <article>
          <p class="drop-cap" style="font-size:var(--text-lg);line-height:var(--leading-loose)">
            {t.historyLead}
          </p>

          <p>{t.historyBody1}</p>

          <blockquote
            style="margin:var(--space-12) 0;padding:var(--space-6) var(--space-8);border-left:3px solid var(--color-gold-bright);background:var(--color-glass);backdrop-filter:var(--glass-blur);border-radius:0 var(--radius-md) var(--radius-md) 0"
          >
            <p class="t-quote" style="font-size:clamp(1.1rem,2.5vw,1.5rem);margin:0">
              "{t.quote}"
            </p>
          </blockquote>

          <p>{t.historyBody2}</p>
          <p>{t.historyBody3}</p>
        </article>
      </div>

      <div style="margin-top:var(--space-16)" data-animate="fade-up">
        <p class="section-label">{t.timelineLabel}</p>
        <div style="position:relative;padding-left:var(--space-8)">
          <div aria-hidden="true" style="position:absolute;left:0;top:0;bottom:0;width:1px;background:linear-gradient(to bottom,var(--color-gold-bright),transparent)"></div>

          {t.timeline.map((item) => (
            <div style="margin-bottom:var(--space-10);position:relative">
              <div style="position:absolute;left:calc(-1 * var(--space-8) - 5px);top:4px;width:10px;height:10px;border-radius:50%;background:var(--color-gold-bright);box-shadow:var(--shadow-gold-xs)"></div>
              <p style="font-family:var(--font-heading);font-size:var(--text-xs);letter-spacing:var(--tracking-widest);text-transform:uppercase;color:var(--color-gold-bright);margin-bottom:var(--space-2)">{item.year}</p>
              <h4 style="font-size:var(--text-lg);color:var(--color-parchment);margin-bottom:var(--space-2)">{item.title}</h4>
              <p style="font-size:var(--text-sm);color:var(--color-vellum)">{item.body}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section section--dark" aria-labelledby="philosophy-heading">
    <div class="container">
      <div style="text-align:center;margin-bottom:var(--space-12)" data-animate="fade-up">
        <p class="section-label" style="justify-content:center">{t.philosophyLabel}</p>
        <h2 id="philosophy-heading">{t.philosophyHeading}</h2>
      </div>

      <div class="alternating-block" data-animate="fade-up">
        <div class="alternating-block__content">
          <h3 style="color:var(--color-gold-pale);margin-bottom:var(--space-4)">{t.philosophy1Title}</h3>
          <p>{t.philosophy1Body}</p>
        </div>
        <div class="alternating-block__image">
          <div style="aspect-ratio:3/2;border:var(--border-gold);border-radius:var(--radius-md);overflow:hidden;background:var(--color-stone)">
            <img src="/media/gdansk_1.jpg" alt="" style="width:100%;height:100%;object-fit:cover;object-position:center;display:block;" />
          </div>
        </div>
      </div>

      <div class="alternating-block" data-animate="fade-up">
        <div class="alternating-block__image">
          <div style="aspect-ratio:2/3;border:var(--border-gold);border-radius:var(--radius-md);overflow:hidden;background:var(--color-stone)">
            <img src="/media/rauschpfeife.jpg" alt="" style="width:100%;height:100%;object-fit:cover;object-position:center;display:block;" />
          </div>
        </div>
        <div class="alternating-block__content">
          <h3 style="color:var(--color-gold-pale);margin-bottom:var(--space-4)">{t.philosophy2Title}</h3>
          <p>{t.philosophy2Body}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="musicians-heading">
    <div class="container">
      <div style="text-align:center;margin-bottom:var(--space-12)" data-animate="fade-up">
        <p class="section-label" style="justify-content:center">{t.meetLabel}</p>
        <h2 id="musicians-heading">{t.meetHeading}</h2>
      </div>

      <div class="grid-3" role="list">
        {musicians.map((musician, index) => {
          const meta = musicianMeta[lang][musician.name as keyof typeof musicianMeta[typeof lang]];
          return (
          <MusicianCard
            name={musician.name}
            instrument={meta.instrument}
            bio={musician.bio[lang]}
            image={musician.image}
            imagePosition={musician.imagePosition}
            lang={lang}
            animateDelay={index + 1}
            sameAs={musician.sameAs}
            moreLabel={meta.moreLabel}
          />
          );
        })}
      </div>
    </div>
  </section>

  <section class="section section--stone" aria-labelledby="gallery-heading">
    <div class="container">
      <div style="text-align:center;margin-bottom:var(--space-12)" data-animate="fade-up">
        <p class="section-label" style="justify-content:center">{t.galleryLabel}</p>
        <h2 id="gallery-heading">{t.galleryHeading}</h2>
      </div>

      <div class="gallery-grid" data-gallery="about">
        {t.gallery.map((item, index) => (
          <GalleryItem
            src={item.src}
            alt={item.alt}
            fullSrc={item.src}
            caption={item.caption}
            animateDelay={(index % 6) + 1}
          />
        ))}
      </div>
    </div>
  </section>
  </div>
</main>

<Footer lang={lang} />

<script define:vars={{ lang }}>
  localStorage.setItem('gt-lang', lang);
</script>
