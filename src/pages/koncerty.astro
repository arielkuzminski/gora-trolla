---
import { getCollection } from 'astro:content';
import ConcertsPageContent from '../components/ConcertsPageContent.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const concertEntries = await getCollection('concerts');
const allConcerts = concertEntries
  .map((entry) => entry.data)
  .sort((a, b) => {
    const aDate = new Date(a.date).getTime();
    const bDate = new Date(b.date).getTime();
    const now = new Date();
    now.setHours(0, 0, 0, 0);
    const aUpcoming = aDate >= now.getTime();
    const bUpcoming = bDate >= now.getTime();
    if (aUpcoming !== bUpcoming) return aUpcoming ? -1 : 1;
    return aUpcoming ? aDate - bDate : bDate - aDate;
  });

const now = new Date();
now.setHours(0, 0, 0, 0);

const SITE_URL = 'https://www.gora-trolla.pl';

const jsonLd = allConcerts
  .filter((concert) => new Date(concert.date).getTime() >= now.getTime())
  .map((concert) => ({
    '@context': 'https://schema.org',
    '@type': 'Event',
    name: concert.title.pl,
    startDate: concert.date,
    eventStatus: 'https://schema.org/EventScheduled',
    eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
    ...(concert.description?.pl && { description: concert.description.pl }),
    ...(concert.poster && { image: `${SITE_URL}${concert.poster}` }),
    url: `${SITE_URL}/koncerty/#${concert.id}`,
    location: {
      '@type': 'Place',
      name: concert.venue.pl,
      address: {
        '@type': 'PostalAddress',
        addressLocality: concert.city,
        addressCountry: 'PL',
      },
    },
    performer: {
      '@type': 'MusicGroup',
      name: 'Góra Trolla',
      url: SITE_URL,
    },
    organizer: {
      '@type': 'MusicGroup',
      name: 'Góra Trolla',
      url: SITE_URL,
    },
  }));
---

<BaseLayout
  title="Koncerty - Góra Trolla | Zespół Muzyki Dawnej"
  description="Koncerty Góry Trolla - muzyka średniowieczna, renesansowa i barokowa na żywo. Nadchodzące i minione występy zespołu."
  lang="pl"
  currentPage="concerts"
  canonicalUrl="https://www.gora-trolla.pl/koncerty/"
  ogLocale="pl_PL"
  alternates={{
    pl: 'https://www.gora-trolla.pl/koncerty/',
    en: 'https://www.gora-trolla.pl/en/concerts/',
  }}
  ogTitle="Koncerty - Góra Trolla"
  ogDescription="Nadchodzące i minione koncerty Góry Trolla."
  jsonLd={jsonLd}
>
  <ConcertsPageContent lang="pl" allConcerts={allConcerts} />
</BaseLayout>
