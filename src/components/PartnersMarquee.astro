---
interface Props {
  lang: 'pl' | 'en';
}

const { lang } = Astro.props;

const label = lang === 'pl' ? 'Partnerzy i organizatorzy' : 'Partners & organisers';

const logos: { src: string; alt: string; wide?: boolean }[] = [
  { src: '/assets/images/partners/pyrkon.svg',          alt: 'Pyrkon — Festiwal Fantastyki, partner Góra Trolla' },
  { src: '/assets/images/partners/scyzorykon.svg',      alt: 'Scyzorykon — Zlot Miłośników Historii, partner Góra Trolla', wide: true },
  { src: '/assets/images/partners/wosp.webp',           alt: 'Wielka Orkiestra Świątecznej Pomocy — koncert Góra Trolla' },
  { src: '/assets/images/partners/jarmark-gdansk.webp', alt: 'Jarmark Dominikański w Gdańsku — partner muzyczny Góra Trolla' },
  { src: '/assets/images/partners/gdansk.webp',         alt: 'Miasto Gdańsk — organizator koncertów muzyki dawnej' },
  { src: '/assets/images/partners/rumia.webp',          alt: 'Miasto Rumia — partner i organizator wydarzeń Góra Trolla' },
  { src: '/assets/images/partners/gmina-choczewo-v2.webp', alt: 'Gmina Choczewo — partner kulturalny Góra Trolla' },
  { src: '/assets/images/partners/gmina-krokowa.webp',  alt: 'Gmina Krokowa — partner kulturalny Góra Trolla' },
  { src: '/assets/images/partners/zamek-bytow.webp',    alt: 'Zamek w Bytowie — scena historyczna koncertów Góra Trolla' },
  { src: '/assets/images/partners/folkowe-ucho.webp',   alt: 'Folkowe Ucho Festiwal — partner Góra Trolla' },
];
---

<section class="section section--partners" aria-labelledby="partners-label">
  <div class="container">
    <div style="text-align:center;margin-bottom:var(--space-10)" data-animate="fade-up">
      <p id="partners-label" class="section-label" style="justify-content:center">{label}</p>
    </div>

    <div class="partners-wall">
      {logos.map((logo) => (
        <div class="partners__logo">
          <img src={logo.src} alt={logo.alt} loading="lazy" decoding="async" style={logo.wide ? 'max-width:200px;height:60px' : undefined} />
        </div>
      ))}
    </div>
  </div>
</section>
