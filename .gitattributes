# Normalize line endings to LF in the repo and on checkout.
# This overrides core.autocrlf for all contributors.
* text=auto eol=lf

# Treat binary assets as binary — never touch line endings.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.svg  binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.mp3   binary
*.mp4   binary
*.ogg   binary
*.wav   binary
