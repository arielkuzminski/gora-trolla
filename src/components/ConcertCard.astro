---
import { useTranslations } from '../i18n/utils';

interface ConcertData {
  id: string;
  title: { pl: string; en: string };
  date: string;
  venue: { pl: string; en: string };
  city: string;
  poster?: string;
  description?: { pl: string; en: string };
}

interface Props {
  concert: ConcertData;
  lang: 'pl' | 'en';
  animateDelay?: number;
}

const { concert, lang, animateDelay } = Astro.props;
const t = useTranslations(lang);

const MONTHS_PL = ['Sty', 'Lut', 'Mar', 'Kwi', 'Maj', 'Cze', 'Lip', 'Sie', 'Wrz', 'Paź', 'Lis', 'Gru'];
const MONTHS_EN = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];

const d = new Date(concert.date);
const day = d.getDate();
const month = lang === 'pl' ? MONTHS_PL[d.getMonth()] : MONTHS_EN[d.getMonth()];
const year = d.getFullYear();
const time = d.getHours().toString().padStart(2, '0') + ':' + d.getMinutes().toString().padStart(2, '0');

const now = new Date();
now.setHours(0, 0, 0, 0);
const upcoming = d >= now;

const title = concert.title[lang];
const venue = concert.venue[lang];
const description = concert.description?.[lang];
const detailHref = '#';
const moreLabel = lang === 'pl' ? 'Szczegóły' : 'Details';
---

<article
  class={`concert-card${upcoming ? '' : ' concert-card--past'}`}
  data-concert-date={concert.date}
  data-upcoming={upcoming ? '1' : '0'}
  data-animate="fade-up"
  data-animate-delay={animateDelay}
  itemscope
  itemtype="https://schema.org/Event"
>
  <div class="concert-card__date">
    <span class="concert-card__day" itemprop="startDate" content={concert.date}>{day}</span>
    <span class="concert-card__month">{month}</span>
    <span class="concert-card__year">{year}</span>
  </div>

  <div class="concert-card__content">
    <h3 class="concert-card__title" itemprop="name">{title}</h3>
    <p class="concert-card__venue" itemprop="location">
      {venue}, {concert.city} &bull; {time}
    </p>

    {description && (
      <p class="concert-card__desc">
        {description}
      </p>
    )}

    {concert.poster && (
      <div class="concert-card__footer">
        <a
          href="#"
          class="btn btn--ghost btn--sm"
          data-poster={concert.poster}
          data-poster-title={title}
        >
          {moreLabel} →
        </a>
      </div>
    )}
  </div>

  <meta itemprop="performer" content="Góra Trolla" />
</article>

<script>
  document.addEventListener('click', (e) => {
    const btn = (e.target as Element)?.closest<HTMLAnchorElement>('a[data-poster]');
    if (!btn) return;
    e.preventDefault();
    window.GoraTrollaLightbox?.open(
      [{ src: btn.dataset.poster!, alt: btn.dataset.posterTitle ?? '' }],
      0
    );
  });
</script>
